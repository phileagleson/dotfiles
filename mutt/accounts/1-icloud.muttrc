# vim: filetype=neomuttrc
# muttrc file for account icloud
set realname = "Phil Eagleson"
set from = "phileagleson@icloud.com"
set sendmail = "msmtp -a icloud"
alias me Phil Eagleson <phileagleson@icloud.com>
set folder = "/Users/phil/.local/share/mail/icloud"
set header_cache = /Users/phil/.cache/mutt-wizard/icloud/headers
set message_cachedir = /Users/phil/.cache/mutt-wizard/icloud/bodies
set mbox_type = Maildir

set crypt_autosign = yes
set crypt_opportunistic_encrypt = yes
set pgp_self_encrypt = yes
set pgp_default_key  = 00684F5F1463FA02

bind index,pager gg noop
bind index,pager g noop
bind index,pager M noop
bind index,pager C noop
bind index gg first-entry
macro index o "<shell-escape>mailsync -V icloud<enter>" "run mbsync to sync icloud"
unmailboxes *

set spoolfile = "+INBOX"
set record = "+Sentry"
set postponed = "+Drafts"
set trash = ""
mailboxes =INBOX\
          =Drafts\
          =Sent\ Messages\
          =Junk\
          =Deleted\ Messages\
          =Archive\
          =Dynu\ (domain\ name)\
          =401k\
          =AWS\
          =Alfred\
          =Amazon\
          =Apple\
          =Apple\ Card\
          =Apple\ developer\
          =Arduino\
          =Balanced\ Life\ Yoga\
          =Barclay\ Card\
          =Beachbody\
          =Benefits\
          =Best\ Buy\
          =Capital\ One\
          =Chase\ Card\
          =Christmas\ 2018\
          =Citizens\ One\ (iPhone\ Loan)\
          =Clay-King\
          =Coinbase\
          =Crutchfield\
          =Digital\ Ocean\
          =Dyson\
          =Epik\ (Domain\ Registration)\
          =Fantastical\
          =Freelancer\
